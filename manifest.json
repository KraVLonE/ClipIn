{
  "manifest_version": 3,
  "name": "LinkedIn → Notion Referral Tracker",
  "version": "1.1",
  "description": "Save LinkedIn profiles to your Notion Referral Contacts database in one click.",
  "browser_specific_settings": {
    "gecko": {
      "id": "linkedin-to-notion@referral-tracker",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.notion.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
